{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "拍拍商品数据研究助手",
  "version": "0.1.0",
  "identifier": "com.paipai.research.assistant",
  "build": {
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "拍拍商品数据研究助手",
        "width": 1100,
        "height": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
